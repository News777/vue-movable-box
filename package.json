{
  "name": "vue-movable-box",
  "author": "News777",
  "version": "1.1.5-beta.3",
  "license": "MIT",
  "files": [
    "lib"
  ],
  "main": "./lib/vue-movable-box.umd.js",
  "module": "./lib/vue-movable-box.es.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/vue-movable-box.es.js",
      "require": "./lib/vue-movable-box.umd.js"
    },
    "./style.css": "./lib/css/VueMovableBox.css"
  },
  "keywords": [
    "vue",
    "vue3",
    "movable",
    "draggable",
    "resizable",
    "component",
    "container",
    "panel"
  ],
  "description": "A Vue 3 component for draggable and resizable containers",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/News777/VueDraggable.git"
  },
  "bugs": {
    "url": "https://github.com/News777/VueDraggable/issues"
  },
  "homepage": "https://github.com/News777/VueDraggable#readme",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "release": "pnpm build && npm publish"
  },
  "dependencies": {
    "decimal.js": "^10.4.3"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "devDependencies": {
    "@tsconfig/node18": "^18.2.2",
    "@types/node": "^18.19.3",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/tsconfig": "^0.5.0",
    "npm-run-all2": "^6.1.1",
    "sass": "^1.69.7",
    "typescript": "~5.3.0",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^3.7.1",
    "vite-plugin-vue-setup-extend": "^0.4.0",
    "vue": "^3.3.11",
    "vue-tsc": "^1.8.25"
  },
  "engines": {
    "node": ">= 18.0.0"
  }
}
